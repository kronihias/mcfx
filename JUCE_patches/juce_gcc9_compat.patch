diff --git a/modules/juce_graphics/juce_graphics_Harfbuzz.cpp b/modules/juce_graphics/juce_graphics_Harfbuzz.cpp
index f15733e6a8..618db82032 100644
--- a/modules/juce_graphics/juce_graphics_Harfbuzz.cpp
+++ b/modules/juce_graphics/juce_graphics_Harfbuzz.cpp
@@ -85,11 +85,17 @@ JUCE_BEGIN_IGNORE_DEPRECATION_WARNINGS
 // expand to a macro that includes a 'defines' expression, which triggers
 // -Wexpansion-to-defined on gcc 7. There's no way to turn that warning off
 // locally, so we sidestep it.
+// mcfx patch (GCC 9 compat): include <utility> before faking __has_builtin.
+// libstdc++ 9 decides whether to use the Clang-only __make_integer_seq
+// builtin by evaluating __has_builtin(__make_integer_seq) inside <utility>;
+// with the macro forced to 1 it takes the Clang path and GCC 9 fails.
+// Including it first (include guards make later includes no-ops) keeps the
+// GCC code path.
+#include <utility>
+
 #if ! defined(__has_builtin) && defined(__GNUC__) && __GNUC__ >= 5
  #define __has_builtin(x) 1
 #endif

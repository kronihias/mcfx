+            if (MACAddressHelpers::createAddress (sockAddr) != interfaceAddress)
+                continue;
+
+            const auto prefix = unicast->OnLinkPrefixLength;
+            if (prefix == 0 || prefix >= 32)
+                return {};
+
+            const uint32 hostBits = 0xffffffffu >> prefix;
+            const uint32 ipBE = (uint32 (interfaceAddress.address[0]) << 24)
+                              | (uint32 (interfaceAddress.address[1]) << 16)
+                              | (uint32 (interfaceAddress.address[2]) << 8)
+                              |  uint32 (interfaceAddress.address[3]);
+
+            return IPAddress (ipBE | hostBits);
+        }
+    }
+
     return {};
